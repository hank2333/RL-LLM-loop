{
  "allowed_params": [
    "learning_rate",
    "n_steps",
    "ent_coef",
    "total_timesteps"
  ],
  "max_params_to_change": 2,
  "param_rules": {
    "learning_rate": {
      "type": "choice",
      "choices": [0.0001, 0.0003, 0.0005, 0.001]
    },
    "n_steps": {
      "type": "choice",
      "choices": [128, 256, 512, 1024]
    },
    "ent_coef": {
      "type": "choice",
      "choices": [0.0, 0.005, 0.01, 0.02, 0.03]
    },
    "total_timesteps": {
      "type": "choice",
      "choices": [2000, 5000, 10000]
    }
  }
}